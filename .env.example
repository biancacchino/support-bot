# Copy to .env and fill in. .env is gitignored.

# Required for answer generation (Phase 4 onward). Phase 0's health check
# does not need it.
GEMINI_API_KEY=

# Defaults below match docker-compose service names. Override only when
# running the app outside compose.
QDRANT_URL=http://qdrant:6333
REDIS_URL=redis://redis:6379/0

# Escalate when the top reranker score is below this.
#
# Deliberately left commented out. The value is measured (see config.py, and the
# Phase 3 notes in tasks/todo.md), and config.py is the single place it lives.
# Pinning it here too is how it goes stale: an .env still carrying the old 0.5
# silently escalated 2 of the 8 genuine test queries, because the env file wins
# over the code default. Uncomment only to deliberately override it.
# CONFIDENCE_THRESHOLD=0.35

# How long a conversation's history survives in Redis.
CONVERSATION_TTL_SECONDS=3600
